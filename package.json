{
  "name": "qs-pid",
  "version": "1.0.0",
  "description": "Quantum-Safe Proof of Income Declaration - ZKP using Circom/SnarkJS with W3C VC 2.0 compliance",
  "main": "src/index.js",
  "scripts": {
    "compile": "circom circuits/incomeProof.circom --r1cs --wasm --sym -o artifacts/",
    "setup": "node scripts/setup.js",
    "prove": "node scripts/prove.js",
    "verify": "node scripts/verify.js",
    "test": "node tests/testQSPID.js",
    "test:vc": "node tests/testVC.js",
    "test:pq": "node tests/testPQ.js",
    "test:security": "node tests/testSecurityAudit.js",
    "test:all": "npm test && npm run test:vc && npm run test:pq && npm run test:security",
    "frontend": "node frontend/server.js"
  },
  "keywords": [
    "zkp",
    "circom",
    "snarkjs",
    "w3c-vc",
    "post-quantum",
    "ml-dsa",
    "proof-of-income"
  ],
  "author": "Rahul Pal",
  "license": "MIT",
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.0",
    "ffjavascript": "^0.3.0"
  },
  "devDependencies": {}
}
